{
  "version": 2,
  "robot": {
    "modules": {
      "spider": {
          "driver": "osgar.platforms.spider:Spider",
          "in": ["can"],
          "out": ["can"],
          "init": {}
      },
      "can": {
          "driver": "can",
          "in": ["raw", "can"],
          "out": ["can", "raw"],
          "init": {"canopen": true}
      },
      "serial": {
          "driver": "serial",
          "in": ["raw"],
          "out": ["raw"],
          "init": {"port": "/dev/ttyS0", "speed": 115200,
                   "rtscts":true, "reset":true}
      },

      "transmitter": {
        "driver": "osgar.drivers.push:Push",
          "init": {
            "bind": true,
            "pubsub": true,
            "endpoint": "tcp://*:5555"
          }
      },

      "receiver": {
        "driver": "osgar.drivers.pull:Pull",
        "init": {
          "bind": true,
          "pubsub": true,
          "endpoint": "tcp://*:5556",
          "outputs": [
            "desired_speed", "reset"
          ]
        }
      }

    },
    "links": [["spider.can", "can.can"],
              ["can.can", "spider.can"],
              ["serial.raw", "can.raw"],
              ["can.raw", "serial.raw"]]
  }
}
